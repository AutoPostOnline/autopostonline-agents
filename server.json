{
  "name": "autopostonline-agents",
  "displayName": "AutoPostOnline Agents",
  "description": "Smart, cheap, convenient social publishing infrastructure for AI agents. Postiz-compatible API, MCP endpoint, drafts, scheduling, publishing, media, and analytics.",
  "homepage": "https://autopostonline.com/agents",
  "docs": "https://autopostonline.com/docs/agents",
  "repository": "https://github.com/AutoPostOnline/autopostonline-agents",
  "apiBaseUrl": "https://app.autopostonline.com/api",
  "mcpEndpoint": "https://app.autopostonline.com/api/mcp",
  "auth": {
    "type": "api_key",
    "headers": [
      "Authorization: Bearer <api_key>",
      "Authorization: <api_key>"
    ]
  },
  "environment": {
    "POSTIZ_API_URL": "https://app.autopostonline.com/api",
    "POSTIZ_API_KEY": "your_api_key"
  },
  "capabilities": [
    "list_integrations",
    "create_drafts",
    "upload_media",
    "schedule_posts",
    "publish_posts",
    "retrieve_analytics"
  ],
  "pricing": {
    "plan": "Agent Unlimited",
    "base": "$9/month",
    "positioning": "low-cost agent publishing infrastructure"
  }
}
